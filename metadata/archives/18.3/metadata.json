      "title": "Religion and Mental Health : the Therapeutic Value of the Teachings of Jesus.",
      "publisher": "Whitestone Publications",
      "publication_date": "2019",
      "languages": [
        {
          "id": "eng"
        }
      ],
      "identifiers": [
        {
          "identifier": "k7SnFD",
